{
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "https://post-umbrella.onrender.com/"
    },
    {
      "source": "/mcp/(.*)",
      "destination": "https://post-umbrella.onrender.com/$1"
    },
    {
      "source": "/auth/callback",
      "destination": "/"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
