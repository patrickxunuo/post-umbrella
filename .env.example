# Post Umbrella Environment Configuration

# Data Provider: 'express' (default) or 'supabase'
# VITE_DATA_PROVIDER=express

# Supabase Configuration (required when using supabase provider)
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Custom proxy function URL (defaults to {SUPABASE_URL}/functions/v1/proxy)
# VITE_SUPABASE_PROXY_URL=
