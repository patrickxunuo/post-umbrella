{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Post Umbrella",
  "version": "0.1.15",
  "identifier": "ca.emonster.post-umbrella",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run client",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Post Umbrella",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["postumbrella"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/patrickxunuo/post-umbrella/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMDBGRjM0RjRFRkI1RkQKUldUOXRlLzBOUDhBM2lPUnRQTEVUL09XaEt1TldsYlB0bnNvRlZFYWJJbXlDa2VIS0U3aHh3OHoK"
    }
  }
}
